{
  "name": "parse_table_conflict",
  "rules": {
    "source_file": {
      "type": "SYMBOL",
      "name": "expr"
    },
    "expr": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            { "type": "SYMBOL", "name": "expr" },
            { "type": "STRING", "value": "+" },
            { "type": "SYMBOL", "name": "expr" }
          ]
        },
        {
          "type": "STRING",
          "value": "x"
        }
      ]
    }
  }
}
