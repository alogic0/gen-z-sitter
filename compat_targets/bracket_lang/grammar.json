{
  "name": "bracket_lang",
  "version": "1.0.0",
  "externals": [
    { "type": "SYMBOL", "name": "open_bracket" },
    { "type": "SYMBOL", "name": "close_bracket" }
  ],
  "rules": {
    "source": {
      "type": "SYMBOL",
      "name": "item"
    },
    "item": {
      "type": "SEQ",
      "members": [
        { "type": "SYMBOL", "name": "open_bracket" },
        {
          "type": "CHOICE",
          "members": [
            { "type": "SYMBOL", "name": "item" },
            { "type": "BLANK" }
          ]
        },
        { "type": "SYMBOL", "name": "close_bracket" }
      ]
    }
  }
}
